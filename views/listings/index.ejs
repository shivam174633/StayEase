<%layout("/layouts/boilerplate")%>

<style>
    #filters {
        display: flex;
        flex-wrap: wrap;
        margin-top: 2rem;
        align-items: center;
    }
    .filter {
        text-align: center;
        margin-right: 2rem;
        opacity: 0.7;
    }
    .filter:hover { opacity: 1; cursor: pointer; }
    .filter p { font-size: 0.8rem; }
    .filter-link { text-decoration: none; color: inherit; }
    .filter-link.active-filter .filter {
        opacity: 1;
        border-bottom: 2px solid black;
        padding-bottom: 4px;
    }
    .tax-info { display: none; }
    .tax-toggle {
        border: 1px solid black;
        border-radius: 1rem;
        height: 3.25rem;
        padding: 1rem;
        margin-left: 5rem;
        display: flex;
        align-items: center;
    }
</style>

<div id="filters">
    <a href="/listings?category=trending" class="filter-link <%= locals.category === 'trending' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-fire"></i></div><p>Trending</p></div>
    </a>
    <a href="/listings?category=rooms" class="filter-link <%= locals.category === 'rooms' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-bed"></i></div><p>Rooms</p></div>
    </a>
    <a href="/listings?category=cities" class="filter-link <%= locals.category === 'cities' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-mountain-city"></i></div><p>Iconic Cities</p></div>
    </a>
    <a href="/listings?category=mountains" class="filter-link <%= locals.category === 'mountains' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-mountain"></i></div><p>Mountains</p></div>
    </a>
    <a href="/listings?category=castles" class="filter-link <%= locals.category === 'castles' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-brands fa-fort-awesome"></i></div><p>Castles</p></div>
    </a>
    <a href="/listings?category=pools" class="filter-link <%= locals.category === 'pools' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-person-swimming"></i></div><p>Amazing Pools</p></div>
    </a>
    <a href="/listings?category=camping" class="filter-link <%= locals.category === 'camping' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-campground"></i></div><p>Camping</p></div>
    </a>
    <a href="/listings?category=farms" class="filter-link <%= locals.category === 'farms' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-tractor"></i></div><p>Farms</p></div>
    </a>
    <a href="/listings?category=arctic" class="filter-link <%= locals.category === 'arctic' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-regular fa-snowflake"></i></div><p>Arctic</p></div>
    </a>
    <a href="/listings?category=domes" class="filter-link <%= locals.category === 'domes' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-igloo"></i></div><p>Domes</p></div>
    </a>
    <a href="/listings?category=boats" class="filter-link <%= locals.category === 'boats' ? 'active-filter' : '' %>">
        <div class="filter"><div><i class="fa-solid fa-sailboat"></i></div><p>Boats</p></div>
    </a>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display Total After Taxes</label>
        </div>
    </div>
</div>

<% if (allListings.length === 0) { %>
    <div class="text-center mt-5">
        <h4>No listings found<% if(locals.q) { %> for "<%= locals.q %>"<% } %>.</h4>
        <a href="/listings" class="btn btn-outline-danger mt-3">Clear Filter</a>
    </div>
<% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for(listings of allListings){ %>
            <a href="/listings/<%=listings._id%>" class="listing-link">
                <div class="card col listing-card">
                    <img src="<%=listings.image.url%>" class="card-img-top" alt="listing image" style="height: 20rem">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%=listings.title%></b><br>
                            &#8377; <%=listings.price?.toLocaleString("en-IN")%>/night
                            <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
        <% } %>
    </div>
<% } %>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (info of taxInfo) {
            if (info.style.display != "inline") { info.style.display = "inline"; }
            else { info.style.display = "none"; }
        }
    })
</script>